<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>User Profile</title>
  </head>
  <body class="flex items-center justify-center h-screen bg-gray-100">
    
    <div class="bg-white shadow-lg rounded-2xl p-8 text-center w-80">
      
      <h1 class="text-2xl font-bold text-gray-800 mb-4">
        User Profile
      </h1>

      <div class="mb-3">
        <span class="text-gray-500 text-sm">User ID</span>
        <p class="text-lg font-semibold text-blue-600">
          {{userId}}
        </p>
      </div>

      <div class="mb-4">
        <span class="text-gray-500 text-sm">User Name</span>
        <p class="text-lg font-semibold text-green-600">
          {{userName}}
        </p>
      </div>

      <a href="/" 
         class="inline-block mt-4 px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">
        Go Home
      </a>

    </div>

  </body>
</html>
